rem_frame() {

  echo -e -n "${yellow}remove frame "

  # grab a random file from PWD
  f=$(find . -maxdepth 1 -mindepth 1 -name '*.mp3' -printf '%f' -quit)
  option="--user-text-frame="

  echo -e "${blue} looking for frames tag..."
  echo -e "$(eyeD3 -l error "$f" | awk '/Frame:/ {print $3}' | sed 's/]//')"

  select descriptor in $(eyeD3 -l error "$f" | awk '/Frame:/ {print $3}' | sed 's/]//'); do
    echo -e "${white}descriptor chosen $descriptor${reset}"
    newdata="$descriptor"
    break
  done

  echo "eyeD3 \"$f\" $option${newdata}"

  if [ -z "$newdata" ]; then
    # print_help
    echo -e " \t no data quitting.\n"
  else
    echo -e "${yellow} about to modify all mp3s in PWD"
    are_we_committing
    if [ "$committing" = 'yes' ]; then
      for f in *.mp3; do
        eyeD3 -l error "$f" $option${newdata}
        # ftb="$(basename "${f%.mp3}")"
      done
    else
      echo -e "${blue}ok... we do nothing then...bailing${reset}"
    fi
  fi
} # rem_object

