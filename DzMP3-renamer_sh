tr_details() {
  echo -e "\t${yellow}track details of an mp3 in pwd${reset}"
  f=$(find . -maxdepth 1 -mindepth 1 -name '*.mp3' -printf '%f' -quit)
  eyeD3 -l error "$f"
  echo -e "${reset}"

  echo -en "${blue}Looking for tag data track/number"
  mp3track="$(eyeD3 -l error "$f" | awk '/track/ {print $2}' | sed 's/\b[0-9]\b/0&/g')" # pad track number 2 spaces
  if [[ -z $mp3track ]]; then
    echo -e "${yellow}, no data found.${reset}"
  else
    echo -e ", ${yellow}\"$mp3track\"${reset}"
    # echo -e "(rename) mv \"$f\" \"$mp3track\"\n"
  fi

  echo -en "${blue}Looking for tag data title"
  mp3title="$(eyeD3 -l error "$f" | awk '/^title:/ {print $0}' | sed 's/^title\: //')"
  if [[ -z $mp3title ]]; then
    echo -e "${yellow}, no data found.${reset}"
  else
    echo -e ", ${yellow}\"$mp3title\"${reset}"
  fi
  echo
  pause
}

tag_insert_num_track() {
  echo -e "${blue}set tag -n (tracknum) from 1st field${reset}"

  for f in *.mp3; do
    ftb="$(basename "${f%.mp3}")"
    echo -e "${blue}ftb ${yellow}\"$ftb\"${reset}"

    mp3track="$(echo "$ftb" | awk '{print $1}')"
    echo -e "${blue}mp3track ${yellow}$mp3track${reset}"
    newtag="n" # -n for track NUM
    newdata="$mp3track"
    echo "set_tag_data \"$newtag\" \"$newdata\""

    mp3title="$(echo "$ftb" | awk '{print $3}')"
    echo -e "${blue}mp3title ${yellow}$mp3title${reset}"
    newtag="t" # -t for track TITLE
    newdata="$mp3title"
    echo "set_tag_data \"$newtag\" \"$newdata\""
  done
}

add_album_art_to_all() {
  # https://stackoverflow.com/questions/24195874/best-way-to-find-files-recursively-that-have-the-same-name-but-are-actually-diff/24197175#24197175

  f=$(find . -maxdepth 1 -mindepth 1 -name '*.mp3' -printf '%f' -quit)
  eyeD3 -l error "$f"

  echo -e "adding album art to all files in this folder"
  echo -e "need path to file and type eg, FRONT_COVER"
  #
  # Select image to use
  #
  images=(*.{gif,jpeg,jpg,png})
  if [[ ${#images[@]} -eq 0 ]]; then
    echo -e "no images found"
    exit
  elif [[ ${#images[@]} -eq 1 ]]; then
    echo -e "We only have ${white}one media to use...${reset}"
    echo -e "${blue}$images${reset}"
    album_art=$images
  elif [[ ${#images[@]} -gt 1 ]]; then
    echo -e "There are ${white}${#images[@]} possibles${reset} to choose from"
    # select descriptor in $(mount | awk '/media/{print $3}')
    select album_art in "${images[@]}"; do
      echo -e "${blue}chosen \"$album_art\" ${reset}"
      break
    done
  else
    echo "Don't know what we've found ${white} bailing out! ${reset}"
  fi
  #
  # Select type - Front or Back cover
  #
  echo -e "select type"
  imagetypes=("FRONT_COVER" "BACK_COVER")
  select arttype in "${imagetypes[@]}"; do
    echo -e "${blue}\"$arttype\"${reset}"
    break
  done
  echo -e "${blue} --add-image \"$album_art:$arttype\"${reset}"

  are_we_committing
  if [[ "$committing" = "yes" ]]; then
    find . -maxdepth 1 -type f -name "*\.mp3" -print0 | while IFS= read -r -d '' file; do
      echo -e "\t${blue}$file${reset}"
      if ! eyeD3 -2 "$file" 2>&1 | grep -q "No ID3 v2.x tag"; then
        #statements
        echo -e "adding image"
        eyeD3 -l error "$file" --add-image "$album_art:$arttype"
        if [[ $? = 0 ]]; then
          echo -en "${white}Success: ${reset}"
          echo -e "${blue}\"$file\"${reset}"
        fi

      else
        echo -e "\t${blue}ID3 v2.x ${white}Not Found${reset}"
      fi
    done
  else
    echo -e "${red}not committed, bailing.\n ${reset}"
    # echo -e "eyeD3  \"$file\"  --add-image \"$album_art:$arttype\""
  fi
} # add_album_art_to_all

ext_album_art() {
  f=$(find . -maxdepth 1 -mindepth 1 -name '*.mp3' -printf '%f' -quit)
  echo -e "${blue}Using $f ...${reset}"
  eyeD3 -l error --write-images . "$f"
} # ext_album_art

flipAround() {
  echo -e "${yellow}\tFlipAround${reset} "
  f=$(find . -maxdepth 1 -mindepth 1 -name '*.mp3' -printf '%f' -quit)
  ftb="$(basename "${f%.mp3}")"
  newdata="$(echo $ftb | sed -E 's/(.*\b)\s?-\s?(\b.*)/\2 - \1/').mp3"
  echo -e "current: $f"
  echo -e "suggest:${yellow} \"$newdata\" ${reset}"
  are_we_committing
  if [[ "$committing" = "yes" ]]; then
    for f in *.mp3; do
      ftb="$(basename "${f%.mp3}")"
      newdata="$(echo $ftb | sed -E 's/(.*\b)\s?-\s?(\b.*)/\2 - \1/').mp3"
      mv "$f" "$newdata"
      if [[ $? = 0 ]]; then
        echo -en "${white}Success: ${reset}"
        echo -e "${blue}mv \"$f\" ${yellow}\"$newdata\" ${reset}"
      fi
    done
  else
    echo -e "${red}not committing, bailing${reset}"
  fi
} # flipAround

are_we_committing() {
  echo -en "${yellow}are_we_committing ?"
  read -e -p " [y] " userentry
  echo -e "${reset}"
  if [ "$userentry" = 'y' ]; then
    committing="yes"
  else
    committing="no"
  fi
}

