check_tag_version() {
  echo -e "check which tags exist"
  are_we_committing
  if [[ "$committing" = "yes" ]]; then
    find . -maxdepth 1 -type f -name "*\.mp3" -print0 | while IFS= read -r -d '' file; do
      # check v1
      if ! eyeD3 -1 "$file" 2>&1 | grep -q "No ID3 v1.x tag"; then
        if [[ $? = 0 ]]; then
          echo -en "${yellow}ID3 v1.x tags in ${reset}"
        fi

      else
        echo -en "${red}ID3 v1.x tags not in ${reset}"
      fi
      echo -e "${blue}\"$file\"${reset}"
      # Check v2
      if ! eyeD3 -2 "$file" 2>&1 | grep -q "No ID3 v2.x tag"; then
        if [[ $? = 0 ]]; then
          echo -en "${yellow}ID3 v2.x tags in ${reset}"
        fi

      else
        echo -en "\t${red}ID3 v2.x tags not in ${reset}"
      fi
      echo -e "${blue}\"$file\"${reset}"
    done
  else
    echo -e "${red}not committed, bailing.\n ${reset}"
  fi
  pause
  echo
}

