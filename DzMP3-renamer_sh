ren_with_track_n_title_tags() {
  echo -e "\t${yellow}rename file using \"track - title\"${reset}"
  echo -e "fields \"As is\" or padded to 2 or 3 spaces?"
  echo -e -n "[${white}2${reset}] digit padding,[${white}3${reset}] digit padding, "
  echo -e "[${white}A${reset}]s is, [${white}Enter${reset}] to Quit"
  read -e -p " > " userentry
  echo -e ${reset}
  if [ -z "$userentry" ]; then
    echo -e "           ...nothing so we are quitting.\n"
    continue="no"
  elif [ "$userentry" = 'a' ]; then
    # As is
    for f in *.mp3; do
      track_num="$(eyeD3 -l error "$f" | awk '/track/ {print $2}' | sed 's/[[:space:]]*$//')"
      title="$(eyeD3 -l error "$f" | awk '/^title:/ {print $0}' | sed 's/title\: //;s/[[:space:]]*$//')"
      new_filename="$track_num - $title.mp3"

      if [ "$f" != "$new_filename" ]; then
        echo -e "file rename with track:num - title"
        echo -e "mv \"$f\" \"$new_filename\" "
        mv "$f" "$new_filename"
      else
        echo -e "Skipping $f - already has correct name"
      fi
    done

  elif [ "$userentry" = '2' ]; then
    # PAD TO TWO DIGITS
    echo -e "file rename with track:num padded 2 - title"
    f=$(find . -maxdepth 1 -mindepth 1 -name '*.mp3' -printf '%f' -quit)
    newtrackname="$(eyeD3 -l error "$f" | awk '/track/ {print $2}' | sed 's/\b[0-9]\b/0&/g;s/[[:space:]]*$//')" # pad track number 2 spaces
    newtrackname="$newtrackname - $(eyeD3 -l error "$f" | awk '/^title:/ {print $0}' | sed 's/title\: //;s/[[:space:]]*$//').mp3"
    echo -e "${blue}newtrackname \"$newtrackname\"${reset}"
    are_we_committing
    if [[ "$committing" = 'yes' ]]; then
      for f in *.mp3; do
        newtrackname="$(eyeD3 -l error "$f" | awk '/track/ {print $2}' | sed 's/\b[0-9]\b/0&/g;s/[[:space:]]*$//')" # pad track number 2 spaces
        newtrackname="$newtrackname - $(eyeD3 -l error "$f" | awk '/^title:/ {print $0}' | sed 's/title\: //;s/[[:space:]]*$//').mp3"

        if [[ "$f" != "$newtrackname" ]]; then
          mv "$f" "$newtrackname"
          if [[ $? = 0 ]]; then
            echo -en "${white}Success: ${reset}"
            echo -e "mv to \"$newtrackname\" "
            echo -e "${blue}\"$f\"${reset}"
          fi
        else
          echo -e "${yellow}Skipping:${reset} \"$f\" already has correct name"
        fi
      done
    fi

  elif [ "$userentry" = '3' ]; then
    # PAD TO THREE DIGITS
    echo -e "file rename with track:num padded 3 - title"
    f=$(find . -maxdepth 1 -mindepth 1 -name '*.mp3' -printf '%f' -quit)
    newtrackname="$(eyeD3 -l error "$f" | awk '/track/ {print $2}' | sed 's/\b[0-9]\b/00&/g; s/\b[0-9]\{2\}\b/0&/g;s/[[:space:]]*$//')" # pad track number 3 spaces
    newtrackname="$newtrackname - $(eyeD3 -l error "$f" | awk '/^title:/ {print $0}' | sed 's/title\: //;s/[[:space:]]*$//').mp3"
    echo -e "${blue}newtrackname \"$newtrackname\"${reset}"
    are_we_committing
    if [[ "$committing" = 'yes' ]]; then
      for f in *.mp3; do
        newtrackname="$(eyeD3 -l error "$f" | awk '/track/ {print $2}' | sed 's/\b[0-9]\b/00&/g; s/\b[0-9]\{2\}\b/0&/g;s/[[:space:]]*$//')" # pad track number 3 spaces
        newtrackname="$newtrackname - $(eyeD3 -l error "$f" | awk '/^title:/ {print $0}' | sed 's/title\: //;s/[[:space:]]*$//').mp3"
        mv "$f" "$newtrackname"
        if [[ $? = 0 ]]; then
          echo -en "${white}Success: ${reset}"
          echo -e "mv to \"$newtrackname\" "
          echo -e "${blue}\"$f\"${reset}"
        fi
      done
    fi
  elif [ -z "$userentry" ]; then
    echo -e "bailing"
  fi
} # ren_with_track_n_title_tags

